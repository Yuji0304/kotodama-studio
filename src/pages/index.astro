---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="言霊.studio | ポッドキャスト運用・オーディオ広告代理店">
  <Header heroFull={true} />

  <main>
    <!-- ============================================================
         HERO — インディゴグラデーション × ロゴ
    ============================================================ -->
    <section class="hero" aria-label="ヒーロー">
      <div class="hero__bg" aria-hidden="true"></div>

      <div class="hero__body">
        <img
          src="/logo-hero.png"
          alt="言霊.studio"
          class="hero__logo"
          fetchpriority="high"
        />
        <p class="hero__tagline">情報に、魂を。ビジネスに、カルチャーを。</p>
        <p class="hero__credit">powered by 4AM</p>
      </div>

      <div class="hero__scroll" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 3v14M4 11l6 6 6-6" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>scroll</span>
      </div>
    </section>

    <!-- ============================================================
         STATS BAR
    ============================================================ -->
    <div class="stats-bar">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item" data-anim>
            <span class="stat-value">800<em>万+</em></span>
            <span class="stat-label">国内ポッドキャスト<br/>月間聴取者数</span>
          </div>
          <div class="stat-sep" aria-hidden="true"></div>
          <div class="stat-item" data-anim data-delay="1">
            <span class="stat-value">2.5<em>倍</em></span>
            <span class="stat-label">オーディオ広告市場<br/>5年成長率</span>
          </div>
          <div class="stat-sep" aria-hidden="true"></div>
          <div class="stat-item" data-anim data-delay="2">
            <span class="stat-value">88<em>%</em></span>
            <span class="stat-label">ながら聴きで<br/>高いリーチ効率</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ============================================================
         SERVICES — [ 01 ] SERVICE
    ============================================================ -->
    <section class="section services-section washi" id="services" style="position:relative;">
      <div class="container" style="position:relative;z-index:1;">
        <div class="section-header" data-anim>
          <span class="section-number">[ 01 ] SERVICE</span>
          <h2 class="section-title">ポッドキャストをコアとした<br/>音声メディアの3本柱</h2>
          <div class="divider"></div>
          <p class="section-desc">
            企画から配信・広告・ブランディングまで、音声メディアに特化したサービスをワンストップで提供します。
          </p>
        </div>

        <div class="services-grid">
          <!-- カード 1 -->
          <article class="svc-card" data-anim data-delay="1">
            <div class="svc-card__icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <circle cx="14" cy="10" r="4.5" stroke="url(#si1)" stroke-width="1.5"/>
                <path d="M6 20c0-4 3.6-7 8-7s8 3 8 7" stroke="url(#si1)" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M3 12c0 6 4.9 11 11 11s11-5 11-11" stroke="url(#si1)" stroke-width="1.3" stroke-linecap="round"/>
                <defs>
                  <linearGradient id="si1" x1="3" y1="3" x2="25" y2="25" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#aad4f5"/><stop offset="1" stop-color="#4a8ec8"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <h3 class="svc-card__title">ポッドキャスト運用</h3>
            <p class="svc-card__desc">
              企画・収録・編集・配信・分析まで、番組制作の全プロセスをワンストップで代行。
              経営者・専門家の知見を音声コンテンツとして最大化します。
            </p>
            <ul class="svc-card__list">
              <li>番組企画・コンセプト設計</li>
              <li>収録・編集・BGM制作</li>
              <li>各プラットフォームへの配信</li>
              <li>リスナー分析・改善提案</li>
            </ul>
            <a href="/services#podcast" class="svc-card__link">
              詳しく見る
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </article>

          <!-- カード 2 -->
          <article class="svc-card" data-anim data-delay="2">
            <div class="svc-card__icon svc-card__icon--gold">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <rect x="3" y="7" width="22" height="14" rx="2.5" stroke="url(#si2)" stroke-width="1.5"/>
                <path d="M3 12h22" stroke="url(#si2)" stroke-width="1.3"/>
                <circle cx="9" cy="17" r="2" fill="url(#si2)"/>
                <path d="M15 17h8" stroke="url(#si2)" stroke-width="1.3" stroke-linecap="round"/>
                <defs>
                  <linearGradient id="si2" x1="3" y1="7" x2="25" y2="21" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#c8a96e"/><stop offset="1" stop-color="#e8c98a"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <h3 class="svc-card__title">デジタルオーディオ広告</h3>
            <p class="svc-card__desc">
              Spotify・ポッドキャストなど主要プラットフォームへのオーディオ広告出稿を一括代行。
              ターゲットに届く音声広告で高い広告効果を実現します。
            </p>
            <ul class="svc-card__list">
              <li>Spotify 広告運用</li>
              <li>ポッドキャスト内広告（ホストリード）</li>
              <li>クリエイティブ制作サポート</li>
              <li>効果測定・レポーティング</li>
            </ul>
            <a href="/services#audio-ads" class="svc-card__link">
              詳しく見る
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </article>

          <!-- カード 3 -->
          <article class="svc-card" data-anim data-delay="3">
            <div class="svc-card__icon svc-card__icon--teal">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <path d="M14 4L6 9v6c0 4.4 3.4 8.5 8 9.5 4.6-1 8-5.1 8-9.5V9L14 4z" stroke="url(#si3)" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M10 14l3 3 5-5" stroke="url(#si3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <defs>
                  <linearGradient id="si3" x1="6" y1="4" x2="22" y2="24" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#79d4c8"/><stop offset="1" stop-color="#4ab8a8"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <h3 class="svc-card__title">ブランディング伴走支援</h3>
            <p class="svc-card__desc">
              音声コンテンツを軸に、SNS運用や内製化サポートまで包括的に支援。
              ブランドの声を継続的に育てるパートナーとして伴走します。
            </p>
            <ul class="svc-card__list">
              <li>ブランド戦略・コンテンツ設計</li>
              <li>SNS運用支援（X・Instagram等）</li>
              <li>社内内製化サポート</li>
              <li>定期戦略レビュー</li>
            </ul>
            <a href="/services#branding" class="svc-card__link">
              詳しく見る
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- ============================================================
         NEWS — [ 02 ] NEWS
    ============================================================ -->
    <section class="section news-section" id="news">
      <div class="container">
        <div class="section-header" data-anim>
          <span class="section-number">[ 02 ] NEWS</span>
          <h2 class="section-title">ニュース</h2>
          <div class="divider"></div>
        </div>

        <ul class="news-list">
          <li class="news-item" data-anim data-delay="1">
            <a href="#" class="news-item__inner">
              <span class="news-item__date">2025.03.01</span>
              <span class="news-item__tag">お知らせ</span>
              <span class="news-item__title">言霊.studioがオフィシャルサイトをリニューアルしました</span>
              <svg class="news-item__arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
          <li class="news-item" data-anim data-delay="2">
            <a href="#" class="news-item__inner">
              <span class="news-item__date">2025.02.15</span>
              <span class="news-item__tag">サービス</span>
              <span class="news-item__title">ブランディング伴走支援サービスの提供を開始しました</span>
              <svg class="news-item__arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
          <li class="news-item" data-anim data-delay="3">
            <a href="#" class="news-item__inner">
              <span class="news-item__date">2025.01.20</span>
              <span class="news-item__tag">メディア</span>
              <span class="news-item__title">デジタルオーディオ広告の効果測定レポートを公開しました</span>
              <svg class="news-item__arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
          <li class="news-item" data-anim data-delay="4">
            <a href="#" class="news-item__inner">
              <span class="news-item__date">2024.12.10</span>
              <span class="news-item__tag">実績</span>
              <span class="news-item__title">2024年の音声メディア運用実績レポートを公開しました</span>
              <svg class="news-item__arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        </ul>

        <div class="news-footer" data-anim>
          <a href="#" class="btn btn-outline news-viewall">
            VIEW ALL
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CTA — [ 03 ] CONTACT US
    ============================================================ -->
    <section class="section cta-section" data-anim>
      <div class="cta-topline" aria-hidden="true"></div>
      <div class="container cta-inner">
        <span class="section-number">[ 03 ] CONTACT US</span>
        <h2 class="cta-title">まずは無料相談から</h2>
        <p class="cta-body">
          ポッドキャスト運用・オーディオ広告に関するご相談、お見積もりはお気軽にどうぞ。<br/>
          担当者が貴社の目標に合わせた最適なプランをご提案します。
        </p>
        <a href="/contact" class="btn btn-primary">
          無料相談を予約する
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #1a2744 0%, #243c6e 55%, #2c4a7c 100%);
  }

  .hero__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0 1.5rem;
    text-align: center;
  }

  @keyframes heroLogoIn {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1);    }
  }

  .hero__logo {
    width: min(58vw, 760px);
    height: auto;
    mix-blend-mode: screen;
    animation: heroLogoIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  .hero__tagline {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    font-weight: 300;
    color: rgba(255,255,255,0.82);
    letter-spacing: 0.18em;
    margin-top: 1.4rem;
    animation: heroLogoIn 1.2s ease 1.0s both;
  }

  .hero__credit {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.18em;
    margin-top: 0.6rem;
    animation: heroLogoIn 1.2s ease 1.3s both;
  }

  @keyframes arrowBounce {
    0%, 100% { transform: translate(-50%, 0);   opacity: 0.45; }
    50%       { transform: translate(-50%, 7px); opacity: 0.9;  }
  }

  .hero__scroll {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    animation: arrowBounce 1.8s ease-in-out infinite;
    z-index: 2;
  }

  .hero__scroll span {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
  }

  /* ============================================================
     STATS BAR
  ============================================================ */
  .stats-bar {
    background: var(--aiz-900);
    border-top: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 2rem 0;
  }

  .stats-grid {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 1.5rem;
    gap: 0.3rem;
  }

  .stat-sep {
    width: 1px;
    height: 44px;
    background: rgba(255,255,255,0.1);
    flex-shrink: 0;
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 700;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .stat-value em { font-style: normal; font-size: 1rem; }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.76rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    max-width: 130px;
  }

  /* ============================================================
     SERVICES
  ============================================================ */
  .services-section { background: var(--aiz-800); }
  .section-header   { margin-bottom: 3.5rem; }

  .section-number {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: rgba(170,200,255,0.45);
    margin-bottom: 0.6rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .svc-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2.4rem;
    position: relative;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .svc-card::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px;
    width: 20px; height: 20px;
    border-top: 2px solid var(--color-accent);
    border-left: 2px solid var(--color-accent);
    opacity: 0.5;
  }

  .svc-card:hover {
    border-color: rgba(121,184,232,0.32);
    transform: translateY(-4px);
    box-shadow: 0 20px 56px rgba(11,22,40,0.6);
  }

  .svc-card__icon {
    width: 56px; height: 56px;
    border-radius: 2px;
    background: var(--gradient-accent-subtle);
    border: 1px solid rgba(121,184,232,0.15);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.5rem;
  }
  .svc-card__icon--gold {
    background: linear-gradient(135deg, rgba(200,169,110,0.13) 0%, rgba(232,201,138,0.13) 100%);
    border-color: rgba(200,169,110,0.22);
  }
  .svc-card__icon--teal {
    background: linear-gradient(135deg, rgba(121,212,200,0.13) 0%, rgba(74,184,168,0.13) 100%);
    border-color: rgba(121,212,200,0.22);
  }

  .svc-card__title  { font-size: 1.1rem; margin-bottom: 0.75rem; letter-spacing: 0.03em; }

  .svc-card__desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-bottom: 1.4rem;
  }

  .svc-card__list {
    list-style: none;
    display: flex; flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 1.8rem;
  }
  .svc-card__list li {
    font-family: var(--font-sans);
    font-size: 0.84rem;
    color: var(--color-text-muted);
    padding-left: 1.15rem;
    position: relative;
  }
  .svc-card__list li::before {
    content: '—';
    position: absolute; left: 0;
    color: var(--color-accent);
    font-size: 0.68rem;
    top: 0.15em;
    opacity: 0.65;
  }

  .svc-card__link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.84rem;
    color: var(--color-accent-light);
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: gap 0.2s;
  }
  .svc-card__link:hover { gap: 0.65rem; }

  /* ============================================================
     NEWS
  ============================================================ */
  .news-section {
    background: var(--aiz-700);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .news-list {
    list-style: none;
    margin-bottom: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .news-item {
    border-bottom: 1px solid var(--color-border);
  }

  .news-item__inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 0.5rem;
    transition: background 0.2s;
  }

  .news-item__inner:hover {
    background: rgba(255,255,255,0.03);
  }

  .news-item__date {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-text-subtle);
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .news-item__tag {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    padding: 0.18rem 0.6rem;
    border: 1px solid var(--color-accent-border);
    border-radius: 100px;
    color: var(--color-accent-light);
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }

  .news-item__title {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    flex: 1;
    transition: color 0.2s;
    line-height: 1.55;
  }

  .news-item__inner:hover .news-item__title { color: var(--color-text); }

  .news-item__arrow {
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform 0.2s, opacity 0.2s;
  }

  .news-item__inner:hover .news-item__arrow {
    transform: translateX(3px);
    opacity: 1;
  }

  .news-footer { text-align: center; }
  .news-viewall { padding: 0.7rem 2.2rem; font-size: 0.82rem; letter-spacing: 0.12em; }

  /* ============================================================
     CTA
  ============================================================ */
  .cta-section {
    position: relative;
    background: linear-gradient(160deg, var(--aiz-900) 0%, var(--aiz-800) 50%, var(--aiz-700) 100%);
    text-align: center;
    overflow: hidden;
  }

  .cta-topline {
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(200,169,110,0.7) 35%,
      rgba(232,201,138,1) 50%,
      rgba(200,169,110,0.7) 65%,
      transparent 100%);
  }

  .cta-inner {
    position: relative; z-index: 1;
  }

  .cta-title {
